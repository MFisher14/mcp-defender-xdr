# Microsoft Defender XDR MCP server. Copy to `.env` and fill in real values.
# See README.md for setup details (cert generation, App Registration, permissions).
# NEVER commit `.env`.

# --- Single-tenant mode ---

AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CERT_PATH=/absolute/path/to/app-cert.pfx
# AZURE_CERT_PASSPHRASE=

# --- Multi-tenant mode (overrides the single-tenant vars above) ---
# See tenants.example.json for the file schema. File must be 0600 on POSIX.
# MCP_DEFENDER_XDR_TENANTS_FILE=/etc/mcp-defender-xdr/tenants.json

# --- Optional tuning ---
# DEFENDER_API_BASE=https://api.securitycenter.microsoft.com
# MCP_DEFENDER_XDR_LOG_LEVEL=INFO
